linters: linters_with_defaults(
    assignment_linter = NULL,
    object_name_linter = object_name_linter(c("snake_case", "CamelCase")),
    object_length_linter = object_length_linter(length = 40L),
    cyclocomp_linter = NULL,
    commented_code_linter = NULL,
    line_length_linter = line_length_linter(120L),
    indentation_linter = indentation_linter(indent = 2L, hanging_indent_style = "never")
  )
exclusions: list("R/RcppExports.R" = Inf)
